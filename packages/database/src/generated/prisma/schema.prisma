  carton_height_mm   Decimal?         @db.Decimal(12, 2)
  net_weight_kg      Decimal?         @db.Decimal(12, 3)
  gross_weight_kg    Decimal?         @db.Decimal(12, 3)
  cbm                Decimal?         @db.Decimal(12, 4)
