generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["billing", "docs", "iam", "inventory", "master", "orders", "planning", "platform", "production", "quality", "shipping"]
}

model invoice_lines {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String   @db.Uuid
  invoice_id          String   @db.Uuid
  line_no             Int
  sales_order_line_id String?  @db.Uuid
  description         String
  quantity            Decimal  @db.Decimal(18, 4)
  unit_price          Decimal  @db.Decimal(18, 4)
  line_amount         Decimal  @db.Decimal(18, 2)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  invoices            invoices @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([invoice_id, line_no])
  @@index([invoice_id], map: "idx_invoice_lines_invoice")
  @@schema("billing")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model invoices {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String             @db.Uuid
  invoice_no       String
  customer_id      String             @db.Uuid
  sales_order_id   String?            @db.Uuid
  shipment_id      String?            @db.Uuid
  invoice_date     DateTime           @db.Date
  due_date         DateTime?          @db.Date
  currency_code    String             @default("USD")
  total_amount     Decimal            @default(0) @db.Decimal(18, 2)
  paid_amount      Decimal            @default(0) @db.Decimal(18, 2)
  status           String             @default("draft")
  notes            String?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  invoice_lines    invoice_lines[]
  payment_receipts payment_receipts[]

  @@unique([tenant_id, invoice_no])
  @@index([customer_id, status], map: "idx_invoices_customer_status")
  @@schema("billing")
}

model payment_receipts {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String   @db.Uuid
  receipt_no     String
  invoice_id     String   @db.Uuid
  payment_date   DateTime @db.Date
  amount         Decimal  @db.Decimal(18, 2)
  payment_method String?
  reference_no   String?
  notes          String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  invoices       invoices @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenant_id, receipt_no])
  @@index([invoice_id], map: "idx_payment_receipts_invoice")
  @@schema("billing")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model document_links {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String    @db.Uuid
  document_id String    @db.Uuid
  ref_type    String
  ref_id      String    @db.Uuid
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  documents   documents @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([document_id], map: "idx_doc_links_doc")
  @@index([ref_type, ref_id], map: "idx_doc_links_ref")
  @@schema("docs")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model documents {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String           @db.Uuid
  storage_key    String
  file_name      String
  mime_type      String?
  file_size      BigInt?
  checksum       String?
  category       String
  uploaded_by    String?          @db.Uuid
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  document_links document_links[]

  @@index([tenant_id, category], map: "idx_docs_tenant_category")
  @@schema("docs")
}

model permissions {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String             @unique
  description      String?
  role_permissions role_permissions[]

  @@schema("iam")
}

model refresh_sessions {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String    @db.Uuid
  refresh_token_hash String
  device_name        String?
  platform           String?
  ip_address         String?
  expires_at         DateTime  @db.Timestamptz(6)
  revoked_at         DateTime? @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  users              users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_refresh_sessions_user")
  @@schema("iam")
}

model role_permissions {
  role_id       String      @db.Uuid
  permission_id String      @db.Uuid
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
  @@index([permission_id], map: "idx_role_permissions_permission")
  @@schema("iam")
}

model roles {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String             @db.Uuid
  code             String
  name             String
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  role_permissions role_permissions[]
  tenants          tenants            @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_roles       user_roles[]

  @@unique([tenant_id, code])
  @@index([tenant_id], map: "idx_roles_tenant")
  @@schema("iam")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sites {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String       @db.Uuid
  code       String
  name       String
  site_type  String
  address    String?
  status     String       @default("active")
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  updated_at DateTime     @default(now()) @db.Timestamptz(6)
  tenants    tenants      @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_roles user_roles[]

  @@unique([tenant_id, code])
  @@index([tenant_id], map: "idx_sites_tenant")
  @@schema("iam")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model tenants {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String   @unique
  name       String
  status     String   @default("active")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  roles      roles[]
  sites      sites[]
  users      users[]

  @@schema("iam")
}

model user_roles {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id String  @db.Uuid
  role_id String  @db.Uuid
  site_id String? @db.Uuid
  roles   roles   @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sites   sites?  @relation(fields: [site_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users   users   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([role_id], map: "idx_user_roles_role")
  @@index([user_id], map: "idx_user_roles_user")
  @@schema("iam")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String             @db.Uuid
  email            String
  full_name        String
  password_hash    String
  phone            String?
  status           String             @default("active")
  last_login_at    DateTime?          @db.Timestamptz(6)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  refresh_sessions refresh_sessions[]
  user_roles       user_roles[]
  tenants          tenants            @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tenant_id, email])
  @@index([tenant_id, status], map: "idx_users_tenant_status")
  @@schema("iam")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bin_locations {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String               @db.Uuid
  warehouse_id       String               @db.Uuid
  bin_code           String
  bin_name           String?
  status             String               @default("active")
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  warehouses         warehouses           @relation(fields: [warehouse_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stock_balances     stock_balances[]
  stock_transactions stock_transactions[]

  @@unique([warehouse_id, bin_code])
  @@index([warehouse_id], map: "idx_bin_locations_warehouse")
  @@schema("inventory")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inventory_reservations {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String     @db.Uuid
  item_id      String     @db.Uuid
  warehouse_id String     @db.Uuid
  ref_type     String
  ref_id       String     @db.Uuid
  reserved_qty Decimal    @db.Decimal(18, 4)
  uom_code     String
  status       String     @default("active")
  created_at   DateTime   @default(now()) @db.Timestamptz(6)
  released_at  DateTime?  @db.Timestamptz(6)
  warehouses   warehouses @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([ref_type, ref_id], map: "idx_inv_res_ref")
  @@schema("inventory")
}

model lots {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  item_id       String    @db.Uuid
  lot_no        String
  received_date DateTime? @db.Date
  expiry_date   DateTime? @db.Date
  supplier_id   String?   @db.Uuid
  metadata      Json      @default("{}")
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  @@unique([tenant_id, item_id, lot_no])
  @@index([item_id], map: "idx_lots_item")
  @@schema("inventory")
}

model stock_balances {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String         @db.Uuid
  warehouse_id    String         @db.Uuid
  bin_location_id String?        @db.Uuid
  item_id         String         @db.Uuid
  lot_id          String?        @db.Uuid
  on_hand_qty     Decimal        @default(0) @db.Decimal(18, 4)
  reserved_qty    Decimal        @default(0) @db.Decimal(18, 4)
  available_qty   Decimal        @default(dbgenerated("(on_hand_qty - reserved_qty)")) @db.Decimal(18, 4)
  uom_code        String
  updated_at      DateTime       @default(now()) @db.Timestamptz(6)
  bin_locations   bin_locations? @relation(fields: [bin_location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses      warehouses     @relation(fields: [warehouse_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([item_id, warehouse_id], map: "idx_stock_balances_item")
  @@schema("inventory")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model stock_transactions {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String         @db.Uuid
  transaction_no   String
  transaction_type String
  warehouse_id     String         @db.Uuid
  bin_location_id  String?        @db.Uuid
  item_id          String         @db.Uuid
  lot_id           String?        @db.Uuid
  quantity         Decimal        @db.Decimal(18, 4)
  uom_code         String
  ref_type         String?
  ref_id           String?        @db.Uuid
  reason           String?
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  created_by       String?        @db.Uuid
  bin_locations    bin_locations? @relation(fields: [bin_location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses       warehouses     @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tenant_id, transaction_no])
  @@index([item_id, created_at(sort: Desc)], map: "idx_stock_tx_item_created")
  @@schema("inventory")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model warehouses {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id              String                   @db.Uuid
  site_id                String?                  @db.Uuid
  warehouse_code         String
  warehouse_name         String
  status                 String                   @default("active")
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  bin_locations          bin_locations[]
  inventory_reservations inventory_reservations[]
  stock_balances         stock_balances[]
  stock_transactions     stock_transactions[]

  @@unique([tenant_id, warehouse_code])
  @@schema("inventory")
}

